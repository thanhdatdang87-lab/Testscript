[app]
title = THG2 Obfuscator
package.name = thg2obfuscator
package.domain = org.thg2
source.dir = .
source.include_exts = py,png,jpg,kv,atlas,lua
version = 1.0
requirements = python3,kivy,lua
orientation = portrait
fullscreen = 0
android.permissions = WRITE_EXTERNAL_STORAGE, READ_EXTERNAL_STORAGE, MANAGE_EXTERNAL_STORAGE
android.api = 33
android.minapi = 21
